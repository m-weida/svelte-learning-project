{
	"name": "svelte-test",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host 127.0.0.1 --port 4173",
		"build": "vite build",
		"preview": "vite preview --host 127.0.0.1 --port 4173",
		"preview:e2e": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "pnpm build && start-server-and-test preview:e2e http://127.0.0.1:4173 \"cypress run\"",
		"test:all": "pnpm check && pnpm lint && pnpm test && pnpm build && pnpm test:e2e",
		"lint": "eslint ."
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"cypress"
		]
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.6.0",
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"cypress": "^15.14.1",
		"eslint": "^10.2.1",
		"eslint-plugin-svelte": "^3.17.1",
		"jsdom": "^29.1.0",
		"start-server-and-test": "^3.0.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"svelte-eslint-parser": "^1.6.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.5"
	}
}
